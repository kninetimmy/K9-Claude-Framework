# Default: treat as text, normalize to LF in the repo.
* text=auto eol=lf

# Shell scripts must be LF — CRLF breaks bash on macOS/Linux.
*.sh        text eol=lf

# PowerShell scripts stay CRLF since they're Windows-native.
*.ps1       text eol=crlf

# Markdown and plain text — LF is fine everywhere.
*.md        text eol=lf
VERSION     text eol=lf
.init-version text eol=lf
